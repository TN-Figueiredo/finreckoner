{
  "ci": {
    "collect": {
      "startServerCommand": "npx serve out -l 3100 --no-clipboard",
      "startServerReadyPattern": "Accepting connections",
      "startServerReadyTimeout": 60000,
      "numberOfRuns": 3,
      "url": [
        "http://localhost:3100/",
        "http://localhost:3100/pillars",
        "http://localhost:3100/pillars/us-ca-tax-basics",
        "http://localhost:3100/blog",
        "http://localhost:3100/blog/wise-vs-traditional-banks-transfer-fees"
      ]
    },
    "assert": {
      "aggregationMethod": "median",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.92 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["error", { "minScore": 0.95 }],
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }]
      }
    }
  }
}
